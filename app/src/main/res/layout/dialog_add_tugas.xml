<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Tugas Baru"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jangan lupa selesaikan tugasmu!"
        android:textSize="13sp"
        android:textColor="#64748B"
        android:layout_marginBottom="24dp" />

    <!-- Input Judul Tugas -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Judul Tugas"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etJudulTugas"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="Contoh: Tugas Bahasa Inggris"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:inputType="text"
        android:layout_marginBottom="16dp"
        android:maxLines="1" />

    <!-- Input Deskripsi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deskripsi"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDeskripsi"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_input_field"
        android:hint="Contoh: Essay tentang descriptive text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:layout_marginBottom="16dp" />

    <!-- Input Deadline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deadline"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDeadline"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="Contoh: Jumat, 24 Mei 2024"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:inputType="text"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="24dp" />

    <!-- Pilih Icon Emoji -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Icon"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iconBook"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#1E40AF"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/iconMath"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#1E40AF"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/iconMosque"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_compass"
                android:tint="#1E40AF"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/iconScience"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="#1E40AF"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/iconHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:tint="#1E40AF"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Pilih Warna Background -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Warna Kategori"
        android:textSize="14sp"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/colorBlue"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_time_blue"
            android:foreground="@drawable/bg_color_circle"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/colorPurple"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_time_purple"
            android:foreground="@drawable/bg_color_circle"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/colorGreen"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_time_green"
            android:foreground="@drawable/bg_color_circle"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/colorOrange"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_time_orange"
            android:foreground="@drawable/bg_color_circle"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/colorPink"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_time_pink"
            android:foreground="@drawable/bg_color_circle"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnBatalTugas"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Batal"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:backgroundTint="#F1F5F9"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnSimpanTugas"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Simpan Tugas"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8B5CF6"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>