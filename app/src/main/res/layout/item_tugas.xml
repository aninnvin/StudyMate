<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Container (Background Warna Mapel) -->
        <LinearLayout
            android:id="@+id/layoutIconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_time_blue"
            android:gravity="center">

            <TextView
                android:id="@+id/tvIkonTugas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Info Tugas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvJudulTugas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Judul Tugas"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvDeskripsiTugas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deskripsi singkat"
                android:textSize="13sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Jumat, 24 Mei"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="Belum"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_status_belum"
            android:textColor="#EF4444" />

    </LinearLayout>
</androidx.cardview.widget.CardView>