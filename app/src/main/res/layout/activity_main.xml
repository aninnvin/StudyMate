<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 1. Header -->
        <RelativeLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:alpha="0">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Pagi,"
                    android:textSize="16sp"
                    android:textColor="#94A3B8"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rita ✨"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnProfileIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#64748B"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- 2. Search Bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutSearch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:alpha="0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#94A3B8" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Cari jadwal atau tugas..."
                    android:textSize="14sp"
                    android:textColor="#0F172A"
                    android:textColorHint="#CBD5E1"
                    android:layout_marginStart="12dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. Menu Utama -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu Utama"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/layoutMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp"
            android:alpha="0">

            <!-- Card Jadwal -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnJadwal"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:backgroundTint="#DBEAFE"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_circle_blue"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="#1E3A8A" />
                    </LinearLayout>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadwal" android:textSize="18sp" android:textStyle="bold" android:textColor="#1E3A8A" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lihat aktivitas" android:textSize="12sp" android:textColor="#3B82F6" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Tugas -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnTugas"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:backgroundTint="#FCE7F3"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_circle_pink"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tugas" android:textSize="18sp" android:textStyle="bold" android:textColor="#831843" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cek deadline" android:textSize="12sp" android:textColor="#DB2777" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- 4. Coming Up List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coming Up"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/layoutComingUp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:alpha="0">

            <!-- Item 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_time_badge"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:00" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Matematika" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bab 4: Aljabar" android:textSize="12sp" android:textColor="#64748B" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play"
                        android:rotation="180"
                        app:tint="#CBD5E1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Item 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_time_badge_purple"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13:00" android:textSize="12sp" android:textStyle="bold" android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tugas B. Inggris" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Essay Deadline" android:textSize="12sp" android:textColor="#64748B" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play"
                        android:rotation="180"
                        app:tint="#CBD5E1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>